    # РџСЂРѕРІРµСЂСЏРµРј, СЏРІР»СЏРµС‚СЃСЏ Р»Рё РїРѕР»СЊР·РѕРІР°С‚РµР»СЊ РјРѕРґРµСЂР°С‚РѕСЂРѕРј
    if moderator_id not in MODERATOR_IDS:
        await callback.answer("РЈ РІР°СЃ РЅРµС‚ РїСЂР°РІ РјРѕРґРµСЂР°С‚РѕСЂР°!", show_alert=True)
        return
    
    # РџСЂРѕРІРµСЂСЏРµРј, РЅРµ Р·Р°РЅСЏС‚ Р»Рё С‚РёРєРµС‚
    if ticket_id not in active_tickets:
        await callback.answer("РўРёРєРµС‚ СѓР¶Рµ Р·Р°РєСЂС‹С‚ РёР»Рё РЅРµ СЃСѓС‰РµСЃС‚РІСѓРµС‚!", show_alert=True)
        return
    
    if active_tickets[ticket_id]['moderator_id'] is not None:
        await callback.answer("Р­С‚РѕС‚ С‚РёРєРµС‚ СѓР¶Рµ РїСЂРёРЅСЏС‚ РґСЂСѓРіРёРј РјРѕРґРµСЂР°С‚РѕСЂРѕРј!", show_alert=True)
        return
    
    # РќР°Р·РЅР°С‡Р°РµРј РјРѕРґРµСЂР°С‚РѕСЂР° РЅР° С‚РёРєРµС‚
    active_tickets[ticket_id]['moderator_id'] = moderator_id
    active_moderator_tickets[moderator_id] = ticket_id
    
    user_id = active_tickets[ticket_id]['user_id']
    
    # РЈРІРµРґРѕРјР»СЏРµРј РїРѕР»СЊР·РѕРІР°С‚РµР»СЏ
    try:
        await bot.send_message(
            user_id,
            f"вњ… Р’Р°С€ С‚РёРєРµС‚ #{ticket_id} РїСЂРёРЅСЏС‚ РјРѕРґРµСЂР°С‚РѕСЂРѕРј. РўРµРїРµСЂСЊ РІС‹ РјРѕР¶РµС‚Рµ РѕР±С‰Р°С‚СЊСЃСЏ РІ СЌС‚РѕРј С‡Р°С‚Рµ."
        )
    except Exception as e:
        logging.error(f"РќРµ СѓРґР°Р»РѕСЃСЊ СѓРІРµРґРѕРјРёС‚СЊ РїРѕР»СЊР·РѕРІР°С‚РµР»СЏ {user_id}: {e}")
    
    await callback.message.edit_text(
        f"{callback.message.text}\n\nвњ… РўРёРєРµС‚ РїСЂРёРЅСЏС‚ РјРѕРґРµСЂР°С‚РѕСЂРѕРј @{callback.from_user.username}"
    )
    await callback.answer("РўРёРєРµС‚ РїСЂРёРЅСЏС‚")

# РћР±СЂР°Р±РѕС‚РєР° СЃРѕРѕР±С‰РµРЅРёР№ РІ Р°РєС‚РёРІРЅРѕРј С‚РёРєРµС‚Рµ (С‚РѕР»СЊРєРѕ РґР»СЏ РјРѕРґРµСЂР°С‚РѕСЂР°, РїСЂРёРЅСЏРІС€РµРіРѕ С‚РёРєРµС‚)
@dp.message()
async def handle_ticket_messages(message: types.Message):
    user_id = message.from_user.id
    text = message.text
    
    # РџСЂРѕРІРµСЂСЏРµРј, СЏРІР»СЏРµС‚СЃСЏ Р»Рё РїРѕР»СЊР·РѕРІР°С‚РµР»СЊ РјРѕРґРµСЂР°С‚РѕСЂРѕРј СЃ Р°РєС‚РёРІРЅС‹Рј С‚РёРєРµС‚РѕРј
    if user_id in active_moderator_tickets:
        ticket_id = active_moderator_tickets[user_id]
        if ticket_id in active_tickets:
            ticket = active_tickets[ticket_id]
            user_to_send = ticket['user_id']
            
            # РЎРїРµС†РёР°Р»СЊРЅР°СЏ РєРѕРјР°РЅРґР° РґР»СЏ Р·Р°РєСЂС‹С‚РёСЏ С‚РёРєРµС‚Р°
            if text and text.lower() == "Р·Р°РєСЂС‹С‚СЊ":
                await message.answer(
                    "Р’С‹ СѓРІРµСЂРµРЅС‹, С‡С‚Рѕ С…РѕС‚РёС‚Рµ Р·Р°РєСЂС‹С‚СЊ С‚РёРєРµС‚?",
                    reply_markup=get_ticket_close_keyboard(ticket_id)
                )
                return
            
            # РџРµСЂРµСЃС‹Р»Р°РµРј СЃРѕРѕР±С‰РµРЅРёРµ РїРѕР»СЊР·РѕРІР°С‚РµР»СЋ
            try:
                await bot.send_message(
                    user_to_send,
                    f"рџ“ћ РњРѕРґРµСЂР°С‚РѕСЂ: {message.text}"
                )
                await message.answer("вњ… РЎРѕРѕР±С‰РµРЅРёРµ РѕС‚РїСЂР°РІР»РµРЅРѕ РїРѕР»СЊР·РѕРІР°С‚РµР»СЋ")
            except Exception as e:
                await message.answer("вќЊ РќРµ СѓРґР°Р»РѕСЃСЊ РѕС‚РїСЂР°РІРёС‚СЊ СЃРѕРѕР±С‰РµРЅРёРµ РїРѕР»СЊР·РѕРІР°С‚РµР»СЋ")
    
    # РџСЂРѕРІРµСЂСЏРµРј, СЏРІР»СЏРµС‚СЃСЏ Р»Рё РїРѕР»СЊР·РѕРІР°С‚РµР»СЊ СѓС‡Р°СЃС‚РЅРёРєРѕРј С‚РёРєРµС‚Р°
    else:
        # РС‰РµРј С‚РёРєРµС‚, РіРґРµ СЌС‚РѕС‚ РїРѕР»СЊР·РѕРІР°С‚РµР»СЊ - Р°РІС‚РѕСЂ
        for ticket_id, ticket in active_tickets.items():
            if ticket['user_id'] == user_id and ticket['moderator_id'] is not None:
                moderator_id = ticket['moderator_id']
                
                # РџРµСЂРµСЃС‹Р»Р°РµРј СЃРѕРѕР±С‰РµРЅРёРµ РјРѕРґРµСЂР°С‚РѕСЂСѓ
                try:
                    await bot.send_message(
                        moderator_id,
                        f"рџ‘¤ РџРѕР»СЊР·РѕРІР°С‚РµР»СЊ: {message.text}"
                    )
                    await message.answer("вњ… РЎРѕРѕР±С‰РµРЅРёРµ РѕС‚РїСЂР°РІР»РµРЅРѕ РјРѕРґРµСЂР°С‚РѕСЂСѓ")
                except Exception as e:
                    await message.answer("вќЊ РќРµ СѓРґР°Р»РѕСЃСЊ РѕС‚РїСЂР°РІРёС‚СЊ СЃРѕРѕР±С‰РµРЅРёРµ РјРѕРґРµСЂР°С‚РѕСЂСѓ")
                break

# Р—Р°РєСЂС‹С‚РёРµ С‚РёРєРµС‚Р°
@dp.callback_query(F.data.startswith("close_ticket_"))
async def close_ticket(callback: types.CallbackQuery):
    ticket_id = int(callback.data.split("_")[2])
    moderator_id = callback.from_user.id
    
    if ticket_id in active_tickets:
        ticket = active_tickets[ticket_id]
        user_id = ticket['user_id']
        
        # РЈРІРµРґРѕРјР»СЏРµРј РїРѕР»СЊР·РѕРІР°С‚РµР»СЏ
        try:
            await bot.send_message(
                user_id,
                "рџ”’ РўРёРєРµС‚ Р±С‹Р» Р·Р°РєСЂС‹С‚ РјРѕРґРµСЂР°С‚РѕСЂРѕРј."
            )
        except Exception as e:
            logging.error(f"РќРµ СѓРґР°Р»РѕСЃСЊ СѓРІРµРґРѕРјРёС‚СЊ РїРѕР»СЊР·РѕРІР°С‚РµР»СЏ {user_id}: {e}")
        
        # РЈРґР°Р»СЏРµРј С‚РёРєРµС‚
        if moderator_id in active_moderator_tickets:
            del active_moderator_tickets[moderator_id]
        del active_tickets[ticket_id]
        
        await callback.message.edit_text(
            f"{callback.message.text}\n\nвњ… РўРёРєРµС‚ #{ticket_id} Р·Р°РєСЂС‹С‚."
        )
        await callback.answer("РўРёРєРµС‚ Р·Р°РєСЂС‹С‚")
    else:
        await callback.answer("РўРёРєРµС‚ РЅРµ РЅР°Р№РґРµРЅ", show_alert=True)

